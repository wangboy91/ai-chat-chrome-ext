{
  "manifest_version": 3,
  "name": "AI \u9875\u9762\u52a9\u624b",
  "description": "\u8bfb\u53d6\u5f53\u524d\u9875\u9762\uff0c\u5e76\u5728 Chrome \u4fa7\u8fb9\u680f\u4e2d\u4e0e OpenAI \u6216 Anthropic \u6a21\u578b\u5bf9\u8bdd\u3002",
  "version": "1.0.0",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "AI \u9875\u9762\u52a9\u624b",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
